# ERP login
ERP_USER_ID=23AB1CD99
ERP_PASSWORD="@123456"

# Security question answers. The ERP randomly shows one of your 3 predefined
# questions on each login. For each, SECQ_ANSWER_N_MATCH is a lowercase
# substring that identifies the question text shown on the page (e.g.
# "favourite pet", "school", "birth"), and SECQ_ANSWER_N is your answer.
SECQ_ANSWER_1_MATCH=" Favourite Pet"
SECQ_ANSWER_1="dog"
SECQ_ANSWER_2_MATCH="Language"
SECQ_ANSWER_2="c plus plus"
SECQ_ANSWER_3_MATCH="Food"
SECQ_ANSWER_3="biryani"

# IMAP (for auto-fetching the OTP mail). For Gmail, use an App Password:
# https://myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=example@gmail.com
IMAP_APP_PASSWORD=@987654
