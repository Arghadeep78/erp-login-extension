{
  "manifest_version": 3,
  "name": "IIT KGP ERP Auto-Login",
  "version": "1.0",
  "description": "One-click login to IIT KGP ERP via a local native helper.",
  "permissions": ["nativeMessaging", "tabs", "scripting"],
  "host_permissions": ["https://erp.iitkgp.ac.in/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icon.png"
  }
}
